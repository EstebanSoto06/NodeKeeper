# =========================================
# NodeKeeper - Root .gitignore
# =========================================

# Dependencies
node_modules/
frontend/node_modules/
backend/node_modules/

# Build outputs
dist/
frontend/dist/
backend/dist/
build/
coverage/

# Environment variables
.env
.env.*
!.env.example

# Logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# Local uploads and generated files
backend/uploads/*
!backend/uploads/.gitkeep
!backend/uploads/evidences/
backend/uploads/evidences/*
!backend/uploads/evidences/.gitkeep

# Prisma local artifacts
backend/prisma/dev.db
backend/prisma/dev.db-journal

# OS files
.DS_Store
Thumbs.db
desktop.ini

# Editor files
.vscode/*
!.vscode/settings.json
!.vscode/extensions.json

# Archives and temporary packages
*.zip
*.rar
*.7z

# Temporary files
tmp/
temp/
.cache/
